{
  "name": "@kiwidata/grimoire",
  "version": "0.2.0",
  "description": "Gherkin + MADR spec-driven development for AI coding assistants",
  "type": "module",
  "bin": {
    "grimoire": "./bin/grimoire.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:bdd": "npm run build && NODE_OPTIONS=\"--import tsx\" cucumber-js",
    "lint": "eslint src/",
    "docs:gen": "tsx scripts/gen-cli-docs.ts",
    "docs:dev": "npm run docs:gen && vitepress dev docs",
    "docs:build": "npm run docs:gen && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "clean": "rm -rf dist/",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "files": [
    ".claude-plugin/",
    "dist/",
    "bin/",
    "templates/",
    "skills/",
    "AGENTS.md",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "gherkin",
    "bdd",
    "madr",
    "adr",
    "spec-driven",
    "ai",
    "claude",
    "codex",
    "cursor"
  ],
  "author": "Kiwi Data",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KiwiData-AI/grimoire.git"
  },
  "homepage": "https://github.com/KiwiData-AI/grimoire#readme",
  "bugs": {
    "url": "https://github.com/KiwiData-AI/grimoire/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@cucumber/gherkin": "^39.0.0",
    "@cucumber/messages": "^32.2.0",
    "chalk": "^5.5.0",
    "commander": "^14.0.0",
    "fast-glob": "^3.3.0",
    "simple-git": "^3.33.0",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "jscpd": "^4.0.9",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "vitepress": "^1.6.4",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "@eslint/eslintrc": {
      "js-yaml": "4.2.0"
    }
  }
}
